# Shared
APP_ENV=development

# Frontend (copy to frontend/.env — see frontend/.env.example)
VITE_API_URL=http://localhost:8000
VITE_COOPERATIVE_ID=1

# Backend (copy to backend/.env — see backend/.env.example)
DATABASE_URL=sqlite:///./backend/agro_os_dev.db
SECRET_KEY=your-secret-key-here
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
AGRO_AI_MODEL_PATH=backend/model_artifacts/agro-ai-rf-v1.joblib
AGRO_AI_AUDIT_LOG_PATH=backend/logs/agro_ai_predictions.jsonl
AGRO_AI_REQUIRE_ARTIFACT=false
SENTRY_DSN=

# Weights & Biases experiment tracking
WANDB_PROJECT=agro-os
WANDB_ENTITY=
WANDB_MODE=offline

# Moolre sandbox
MOOLRE_API_URL=https://sandbox.moolre.com
MOOLRE_API_USER=
MOOLRE_API_KEY=
MOOLRE_API_PUBKEY=
MOOLRE_API_VASKEY=
MOOLRE_ACCOUNT_NUMBER=
MOOLRE_MERCHANT_ID=
MOOLRE_MERCHANT_CODE=
MOOLRE_WEBHOOK_SECRET=
USSDK_HOOK_SECRET=

# Notifications
DEFAULT_SMS_SENDER_ID=AgroOS
