{
  "name": "agro-os-workspace",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview",
    "api": "cd backend && ../.venv/bin/uvicorn main:app --reload",
    "train:ai": "PYTHONPATH=backend .venv/bin/python -m app.agro_ai.train",
    "test:backend": "PYTHONPATH=backend .venv/bin/python -m pytest backend/tests",
    "purge:demo": "PYTHONPATH=backend .venv/bin/python backend/scripts/purge_demo_data.py",
    "purge:demo:dry-run": "PYTHONPATH=backend .venv/bin/python backend/scripts/purge_demo_data.py --dry-run",
    "test:frontend": "npm --prefix frontend run test",
    "setup:backend": "python3 -m venv .venv && .venv/bin/python -m pip install -r backend/requirements.txt",
    "setup:frontend": "npm --prefix frontend install"
  }
}
